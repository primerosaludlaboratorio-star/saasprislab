# ==============================================================================
# PRISLAB V5 - Variables de Entorno (EJEMPLO)
# ==============================================================================
# Copia este archivo como .env y completa tus valores.
# NUNCA commitees .env al repositorio.
#
#   cp .env.example .env
#
# En produccion: copiar como /opt/prislab/.env y proteger con chmod 600

# --- Entorno (development | production) ---
PRISLAB_ENV=development

# --- Django ---
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SERVER_NAME=

# --- CSRF (OBLIGATORIO en produccion con HTTPS) ---
CSRF_TRUSTED_ORIGINS=

# --- URL pública del sitio ---
SITE_URL=http://localhost:8000

# --- CORS ---
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=False

# --- Base de Datos (PostgreSQL) ---
DB_NAME=prislab_v5
DB_USER=prislab_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# --- Google Cloud (opcional) ---
GOOGLE_CLOUD_PROJECT=
CLOUD_SQL_CONNECTION_NAME=
GS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# --- APIs (IA, Facturacion) ---
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=
FACTURAMA_USER=your-facturama-user
FACTURAMA_PASSWORD=your-facturama-password
FACTURAMA_SANDBOX=True

# --- Tokens de servicio ---
PRISLAB_API_TOKEN=
PRISLAB_FRONTEND_LOG_TOKEN=
PRISLAB_KIOSCO_API_TOKEN=
PRISCI_WEBHOOK_TOKEN=
PRISCI_WEBHOOK_VERIFY_TOKEN=
CRON_SECRET=
FERNET_KEY=

# --- HL7 / middleware local ---
HL7_ACTIVE=False
HL7_API_KEY=
HL7_ALLOWED_IPS=127.0.0.1
HL7_IP_EMPRESA_MAP={"127.0.0.1":1}

# --- PRIS Sentinel / GitHub ---
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# --- Email ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PRISLAB <noreply@prislab.app>
DIRECTOR_EMAIL=director@empresa.com

# --- Solo desarrollo ---
DEV_ADMIN_USER=admin
DEV_ADMIN_EMAIL=admin@prislab.com
DEV_ADMIN_PASSWORD=change-in-dev-only

# --- Provision inicial ---
PRISLAB_INIT_PASSWORD=change-me-in-production
PRISLAB_QA_ADMIN_PASSWORD=

# --- Redis (opcional) ---
REDIS_URL=redis://localhost:6379/0

# --- Seguridad ---
LAB_VALIDATION_PIN=change-me-in-production-min-8-chars
# OBLIGATORIO en producción: ID numérico del usuario de sistema para auditoría clínica (Escudo HL7/LIMS)
# Genera el usuario primero y luego pon aquí su ID de BD: python manage.py shell -c "from django.contrib.auth import get_user_model; print(get_user_model().objects.get(username='sistema').pk)"
PRISLAB_ESCUDO_USUARIO_ID=
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
DRIVE_FOLDER_ID=
DRIVE_CREDENTIALS_FILE=

# --- VAPID (Web Push) ---
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
