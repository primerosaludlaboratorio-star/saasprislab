# ==============================================================================
# PRISLAB V5 - Variables de Entorno (Ejemplo)
# ==============================================================================
# Copiar a .env y completar con valores reales. NUNCA commitear .env al repositorio.

# --- Django ---
# En producción OBLIGATORIO; en local se usa fallback (settings emite warning si falta en prod)
PRISLAB_ENV=production
SECRET_KEY=generate-a-random-key-here-min-50-chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,216.238.89.243
DOMAIN_NAME=yourdomain.com

# --- CORS ---
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=False

# --- Base de Datos (PostgreSQL en producción) ---
DB_NAME=prislab_v5
DB_USER=prislab_user
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432
# PostgreSQL local en la VPS o instancia administrada propia

# --- Google Drive (producto Google) ---
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=/opt/prislab/credentials/google-drive.json
GOOGLE_DRIVE_TOKEN_PATH=/opt/prislab/credentials/token.json
GOOGLE_DRIVE_CREDENTIALS_PATH=/opt/prislab/credentials/credentials.json

# --- APIs (IA, Facturación) ---
AI_PROVIDER=gemini
# Opcional: solo si quieres usar DeepSeek en vez de Gemini.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-key-if-used
FACTURAMA_USER=your-facturama-user
FACTURAMA_PASSWORD=your-facturama-password
FACTURAMA_SANDBOX=True

# --- Tokens de servicio / integraciones ---
# Usados por endpoints sin sesion humana. Genere valores aleatorios largos.
PRISLAB_API_TOKEN=replace-with-random-service-token
PRISLAB_FRONTEND_LOG_TOKEN=replace-with-random-frontend-log-token
PRISLAB_KIOSCO_API_TOKEN=replace-with-random-kiosco-token
PRISCI_WEBHOOK_TOKEN=replace-with-random-prisci-webhook-token
PRISCI_WEBHOOK_VERIFY_TOKEN=replace-with-random-meta-verify-token
CRON_SECRET=replace-with-random-cron-secret
FERNET_KEY=

# --- DRP / Solo Lectura ---
# Kill switch global: 1/true/yes/on bloquea mutaciones HTTP excepto login/logout/2FA.
PRISLAB_READ_ONLY=1
# Bypass controlado para auditoría funcional en rutas acotadas.
PRISLAB_READ_ONLY_AUDIT_ALLOWED_PATH_PREFIXES=/farmacia/,/inventario/,/pdv/
PRISLAB_READ_ONLY_AUDIT_ALLOWED_USERNAMES=auditor.farmacia,admin
PRISLAB_READ_ONLY_AUDIT_ALLOWED_ROLES=ADMIN,DIRECTOR,GERENTE
PRISLAB_READ_ONLY_ALLOW_SUPERUSERS=False

# HL7 / middleware local
HL7_ACTIVE=False
HL7_API_KEY=replace-with-random-hl7-api-key
HL7_ALLOWED_IPS=127.0.0.1
HL7_IP_EMPRESA_MAP={"127.0.0.1":1}

# --- PRIS Sentinel / GitHub ---
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=owner/repo

# --- Email (notificaciones al director) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PRISLAB <noreply@prislab.app>
DIRECTOR_EMAIL=director@empresa.com

# --- Solo desarrollo / scripts de creación de usuarios ---
DEV_ADMIN_USER=admin
DEV_ADMIN_EMAIL=admin@prislab.com
DEV_ADMIN_PASSWORD=change-in-dev-only

# --- CICLO 12: Provisión inicial (crear_superusuario_admin.py, provision_usuarios.py) ---
# En producción defina PRISLAB_INIT_PASSWORD (se usa para todos si no se definen los individuales)
PRISLAB_INIT_PASSWORD=change-me-in-production
# Opcionales por usuario: PRISLAB_INIT_ADMIN_PASSWORD, PRISLAB_INIT_PASSWORD_BRIZIA, etc.
# QA: PRISLAB_QA_ADMIN_PASSWORD (auditoria_qa management command)
PRISLAB_QA_ADMIN_PASSWORD=

# --- Redis (opcional) ---
REDIS_URL=redis://localhost:6379/0

# --- Otros ---
# LAB_VALIDATION_PIN: minimo 8 caracteres en produccion (ISO/gobierno de acceso)
LAB_VALIDATION_PIN=CambiarEnProduccion2026!
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
DRIVE_FOLDER_ID=
DRIVE_CREDENTIALS_FILE=credentials.json

# VAPID (Web Push)
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key

# --- Academia / Bunny Stream ---
BUNNY_LIBRARY_ID=your-bunny-library-id
BUNNY_STREAM_API_KEY=your-bunny-stream-api-key
BUNNY_EMBED_SECURITY_KEY=your-bunny-embed-security-key
BUNNY_PLAYER_BASE_URL=https://player.mediadelivery.net/embed

# --- Academia / Permisos por empresa ---
# Formato: nombre, slug o ID. Por defecto: PRISLAB
ACADEMIA_EMPRESAS_PERMITIDAS=prislab
