# ==============================================================================
# PRISLAB V5 - Variables de Entorno (Ejemplo)
# ==============================================================================
# Copiar a .env y completar con valores reales. NUNCA commitear .env al repositorio.

# --- Django ---
# En producción OBLIGATORIO; en local se usa fallback (settings emite warning si falta en prod)
SECRET_KEY=generate-a-random-key-here-min-50-chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,.run.app

# --- Base de Datos (PostgreSQL en producción) ---
DB_NAME=prislab_v5
DB_USER=prislab_user
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432
# Cloud SQL: DB_HOST=/cloudsql/PROJECT:REGION:INSTANCE

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-project-id
CLOUD_SQL_CONNECTION_NAME=your-project:region:instance-name
GS_BUCKET_NAME=your-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- APIs (IA, Facturación) ---
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-key-if-used
FACTURAMA_USER=your-facturama-user
FACTURAMA_PASSWORD=your-facturama-password
FACTURAMA_SANDBOX=True

# --- PRIS Sentinel / GitHub ---
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=owner/repo

# --- Email (notificaciones al director) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PRISLAB <noreply@prislab.app>
DIRECTOR_EMAIL=director@empresa.com

# --- Solo desarrollo / scripts de creación de usuarios ---
DEV_ADMIN_USER=admin
DEV_ADMIN_EMAIL=admin@prislab.com
DEV_ADMIN_PASSWORD=change-in-dev-only

# --- CICLO 12: Provisión inicial (crear_superusuario_admin.py, provision_usuarios.py) ---
# En producción defina PRISLAB_INIT_PASSWORD (se usa para todos si no se definen los individuales)
PRISLAB_INIT_PASSWORD=change-me-in-production
# Opcionales por usuario: PRISLAB_INIT_ADMIN_PASSWORD, PRISLAB_INIT_PASSWORD_BRIZIA, etc.
# QA: PRISLAB_QA_ADMIN_PASSWORD (auditoria_qa management command)
PRISLAB_QA_ADMIN_PASSWORD=

# --- Redis (opcional) ---
REDIS_URL=redis://localhost:6379/0

# --- Otros ---
LAB_VALIDATION_PIN=1234
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
DRIVE_FOLDER_ID=
DRIVE_CREDENTIALS_FILE=credentials.json

# VAPID (Web Push)
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
