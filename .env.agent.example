# ─────────────────────────────────────────────────────────────────────────────
# PRISLAB AI Agent Audit — Configuración de entorno
# Copia este archivo como .env.agent y rellena tus valores.
# NUNCA subas .env.agent al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Proveedor LLM ─────────────────────────────────────────────────────────────
# Opciones: openai | anthropic | gemini | ollama
AGENT_PROVIDER=openai

# API Key del proveedor (no requerida para Ollama)
AGENT_API_KEY=sk-...

# Modelo a usar (si se omite, se usa el default del proveedor)
# OpenAI:    gpt-4o | gpt-4o-mini | gpt-4-turbo
# Anthropic: claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# Gemini:    gemini-1.5-pro | gemini-1.5-flash
# Ollama:    llama3.1 | mistral | qwen2.5
AGENT_MODEL=gpt-4o

# URL base del LLM (solo para Ollama o proxies OpenAI-compatible)
# AGENT_BASE_URL=http://localhost:11434

# Temperatura del modelo (0.0 = determinista, 1.0 = creativo)
AGENT_TEMPERATURE=0.2

# ── Target PRISLAB ────────────────────────────────────────────────────────────
# local | cloud
AGENT_TARGET=cloud

# URL base de la app (si se omite, usa el default del manifest)
# PRISLAB_BASE_URL=https://prislab-saas-811785477499.us-central1.run.app

# Credenciales de prueba (usuario con acceso a todos los módulos recomendado)
AGENT_USER=admin
AGENT_PASS=tu_password_aqui

# ── Comportamiento del agente ─────────────────────────────────────────────────
# Máximo de pasos en el bucle de razonamiento (default 60)
AGENT_MAX_STEPS=60

# Milisegundos entre acciones Playwright (default 120)
AGENT_SLOW_MO=120

# 1 = headless (sin ventana), 0 = navegador visible
AGENT_HEADLESS=0

# Módulos a auditar separados por coma (vacío = todos)
# Ejemplo: AGENT_MODULES=laboratorio,farmacia,seguridad
AGENT_MODULES=
