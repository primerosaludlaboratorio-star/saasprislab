# Plantilla para tools/run_ai_agent_audit.mjs (auditor humano IA · Gemini + Playwright).
# Copia a `.env.agent` y rellena. NO lo subas con secretos (añádelo a .gitignore).
#
# Uso:
#   node tools/run_ai_agent_audit.mjs --target cloud   # prod
#   node tools/run_ai_agent_audit.mjs --target local   # http://127.0.0.1:8000

# --- IA (obligatorio) ---
AGENT_API_KEY=                      # API key de Gemini (aistudio.google.com)
AGENT_MODEL=gemini-2.5-flash

# --- Objetivo ---
AGENT_TARGET=cloud                  # cloud | local
PRISLAB_BASE_URL=https://prislab.labcorecloud.com

# --- Credenciales de login (obligatorio para flujos autenticados) ---
AGENT_USER=
AGENT_PASS=

# --- Opcionales ---
AGENT_MAX_STEPS=160
AGENT_HEADLESS=0                    # 0 = ver el navegador, 1 = headless
