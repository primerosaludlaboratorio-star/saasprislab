# ==============================================================================
# PRISLAB V5 — Variables de Entorno PRODUCCIÓN (VPS Vultr / Ubuntu + Nginx)
# ==============================================================================
# Guardar como /opt/prislab/.env en la VPS
# Proteger: chmod 600 /opt/prislab/.env
# NO commitear este archivo con valores reales.
# ==============================================================================

# --- Entorno ---
PRISLAB_ENV=production
DEBUG=False

# --- Django ---
SECRET_KEY=GENERAR-CON-python-get_random_secret_key-min-50-chars
# Dominio real de la VPS + IP (separados por coma)
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,.tu-dominio.com,IP_DE_LA_VPS
SERVER_NAME=tu-dominio.com

# --- CSRF (OBLIGATORIO con HTTPS) ---
CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com,https://*.tu-dominio.com

# --- URL pública del sitio (para QR en resultados de laboratorio) ---
SITE_URL=https://tu-dominio.com

# --- HTTPS hardening ---
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# --- CORS ---
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://tu-dominio.com

# --- Base de Datos PostgreSQL (local en la VPS) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=prislab_db
DB_USER=prislab_user
DB_PASSWORD=CLAVE-SEGURA-POSTGRESQL
# VPS pequeña: cerrar conexiones al final del request evita saturar PostgreSQL con idle slots.
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=True

# --- Google Drive (archivos clínicos y respaldos) ---
# Opción A: JSON del Service Account completo como env var
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Opción B: ruta al archivo JSON en la VPS
# GOOGLE_APPLICATION_CREDENTIALS=/opt/prislab/credentials/google-drive.json
# Opción C recomendada para cuentas personales Gmail (OAuth 2.0)
GOOGLE_DRIVE_TOKEN_PATH=/opt/prislab/credentials/token.json
GOOGLE_DRIVE_CREDENTIALS_PATH=/opt/prislab/credentials/credentials.json
GOOGLE_DRIVE_FOLDER_ID=ID-DE-TU-CARPETA-DRIVE
DRIVE_FOLDER_ID=ID-DE-TU-CARPETA-DRIVE

# --- IA (Gemini canonico + DeepSeek opcional) ---
AI_PROVIDER=gemini
GOOGLE_API_KEY=tu-clave-gemini
GEMINI_API_KEY=tu-clave-gemini
# Opcional: solo si quieres usar DeepSeek como proveedor primario o fallback.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Tokens de servicio (generados con secrets.token_urlsafe(48)) ---
PRISLAB_API_TOKEN=GENERAR-TOKEN-LARGO-ALEATORIO
PRISLAB_FRONTEND_LOG_TOKEN=GENERAR-TOKEN-LARGO-ALEATORIO
PRISLAB_KIOSCO_API_TOKEN=GENERAR-TOKEN-LARGO-ALEATORIO
PRISCI_WEBHOOK_TOKEN=GENERAR-TOKEN-LARGO-ALEATORIO
PRISCI_WEBHOOK_VERIFY_TOKEN=GENERAR-TOKEN-LARGO-ALEATORIO
CRON_SECRET=GENERAR-TOKEN-LARGO-ALEATORIO

# --- Seguridad clínica ---
FERNET_KEY=GENERAR-CON-Fernet.generate_key().decode()
LAB_VALIDATION_PIN=MINIMO-8-CHARS-ALFANUMERICO
PRISLAB_ESCUDO_USUARIO_ID=1  # ID del usuario sistema (crearlo primero)

# --- Email (para notificaciones al director) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PRISLAB <noreply@tu-dominio.com>
DIRECTOR_EMAIL=director@tu-empresa.com

# --- Redis (para cache, WebSockets, Celery) ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- VAPID (Web Push notifications) ---
# Generar: python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); ..."
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# --- Gunicorn ---
GUNICORN_WORKERS=4
GUNICORN_THREADS=4

# --- Facturación SAT (CFDI 4.0) ---
FACTURAMA_USER=
FACTURAMA_PASSWORD=
FACTURAMA_SANDBOX=False

# --- Otros opcionales ---
HL7_ACTIVE=False
SYSTEM_MAINTENANCE_MODE=false

# --- Academia / Diplomados ---
# Por defecto solo PRISLAB. Agregar nombre, slug o ID de otras empresas habilitadas.
ACADEMIA_EMPRESAS_PERMITIDAS=prislab
